{
  "name": "@your-org/forms-example-vite-react",
  "version": "0.0.0",
  "private": true,
  "description": "Runnable Vite React example proving the form renderer in a browser.",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "vite build",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "lint": "eslint .",
    "preview": "vite preview --host 127.0.0.1",
    "test:e2e": "playwright test",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@your-org/forms-adapters": "workspace:*",
    "@your-org/forms-core": "workspace:*",
    "@your-org/forms-react-builder": "workspace:*",
    "@your-org/forms-react-renderer": "workspace:*",
    "@your-org/forms-validators": "workspace:*",
    "react": "^19.2.1",
    "react-dom": "^19.2.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "vite": "^7.2.7"
  }
}
