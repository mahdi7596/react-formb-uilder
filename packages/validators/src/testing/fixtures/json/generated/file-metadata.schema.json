{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "attachment": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["fileId"],
        "additionalProperties": false,
        "properties": {
          "fileId": { "type": "string" },
          "name": { "type": "string" },
          "mimeType": { "type": "string" },
          "size": { "type": "number", "minimum": 0 }
        }
      }
    }
  }
}
